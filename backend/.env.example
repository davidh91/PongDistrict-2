# PongDistrict Backend Environment Variables

# A long, random string used for JWT signing
SECRET_KEY=your_secret_key_here

# Comma-separated frontend origins allowed to call the API
FRONTEND_ORIGINS=http://localhost:5173

# Set to true behind HTTPS in production so auth cookies are secure-only
COOKIE_SECURE=false

# SlowAPI storage backend (memory:// for local dev, redis://host:6379/0 for production)
RATE_LIMIT_STORAGE_URI=memory://

# (Optional) Database URL - defaults to sqlite:///./pongdistrict.db
# For production PostgreSQL (e.g. Render): postgresql://user:pass@host/dbname
# DATABASE_URL=sqlite:///./pongdistrict.db
